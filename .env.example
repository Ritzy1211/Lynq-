# =============================================================================
# Lynq — environment variables (example).
# Copy to `.env` at the repo root and fill in real values for local dev.
# =============================================================================

NODE_ENV=development

# ---- Database (Postgres) ----------------------------------------------------
# For local dev: docker run --name lynq-pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lynq?schema=public

# ---- Redis (BullMQ + cache) -------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---- API --------------------------------------------------------------------
API_PORT=4000
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000

# JWT secret for service-issued tokens (generate with `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-32-byte-random-hex-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Auth (Supabase) --------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---- Payments (Paystack — Nigeria primary) ----------------------------------
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ---- Payments (Flutterwave — fallback) --------------------------------------
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

# ---- WhatsApp Cloud API -----------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ---- SMS fallback (Termii) --------------------------------------------------
TERMII_API_KEY=
TERMII_SENDER_ID=Lynq

# ---- Object storage (Cloudflare R2 — S3 compatible) -------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=lynq-assets
R2_PUBLIC_BASE_URL=

# ---- Web --------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# ---- Observability ----------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=debug
