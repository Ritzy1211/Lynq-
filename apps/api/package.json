{
  "name": "@lynq/api",
  "version": "0.1.0",
  "private": true,
  "description": "Lynq NestJS API — orders, payments, notifications, multi-tenant.",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
